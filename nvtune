MANGOHUD_CONF = """\
# nvtune MangoHud config — in-game overlay
fps
frametime
gpu_stats
gpu_temp
gpu_junction_temp
gpu_mem_temp
gpu_core_clock
gpu_mem_clock
gpu_power
vram
cpu_stats
cpu_temp
ram
gpu_name
engine_version
vulkan_driver
position=top-left
font_size=20
background_alpha=0.4
toggle_hud=Shift_R+F12
"""

def cmd_osd(args):
    if args.action == "install":
        if have("mangohud"):
            print("MangoHud already installed.")
        else:
            print("Installing MangoHud (apt)…")
            r = subprocess.run(_as_root(["apt-get", "install", "-y", "mangohud"]),
                               text=True)
            if r.returncode != 0:
                die("apt install mangohud failed")
        cmd_osd_config(args)
    elif args.action == "config":
        cmd_osd_config(args)
    elif args.action == "run":
        if not have("mangohud"):
            die("MangoHud not installed — run:  nvtune osd install")
        if not args.command:
            die("give a command:  nvtune osd run -- <game/launcher>")
        os.execvp("mangohud", ["mangohud"] + args.command)

def cmd_osd_config(args):
    conf = Path.home() / ".config" / "MangoHud" / "MangoHud.conf"
    conf.parent.mkdir(parents=True, exist_ok=True)
    conf.write_text(MANGOHUD_CONF)
    print(f"wrote MangoHud overlay config -> {conf}")
    print("Use it by launching a game as:  mangohud <game>   (or: nvtune osd run -- <game>)")
    print("For Steam, set launch options to:  mangohud %command%")

# -------------------------------------------------------------------- main ----

def build_parser():
    p = argparse.ArgumentParser(prog="nvtune",
        description="MSI-Afterburner-style undervolt / monitor / OSD for NVIDIA on Linux")
    p.add_argument("-i", "--gpu", type=int, default=0, help="GPU index (default 0)")
    sub = p.add_subparsers(dest="cmd")

    m = sub.add_parser("monitor", help="live TUI dashboard")
    m.add_argument("--interval", type=float, default=1.0)
    m.set_defaults(func=cmd_monitor)

    s = sub.add_parser("set", help="apply individual tuning values")
    s.add_argument("--power", type=int, help="power limit in watts")
    s.add_argument("--lock-clock", help="lock core clock 'MIN,MAX' or 'FREQ'")
    s.add_argument("--gpu-offset", type=int, help="core clock offset MHz (needs Coolbits)")
    s.add_argument("--mem-offset", type=int, help="memory clock offset MHz, real/GPU-Z scale (needs Coolbits)")
    s.add_argument("--fan", type=int, help="fan speed %% (needs Coolbits)")
    s.set_defaults(func=cmd_set)

    u = sub.add_parser("undervolt", help="lock core clock + cap power (Linux undervolt)")
    u.add_argument("--clock", type=int, required=True, help="locked core clock MHz")
    u.add_argument("--power", type=int, required=True, help="power limit W")
    u.add_argument("--gpu-offset", type=int, help="optional +offset MHz (needs Coolbits)")
    u.set_defaults(func=cmd_undervolt)

    r = sub.add_parser("reset", help="revert to stock clocks / power / offsets")
    r.set_defaults(func=cmd_reset)

    pr = sub.add_parser("profile", help="save/apply/list/remove tuning profiles")
    pr.add_argument("action", choices=["save", "apply", "list", "rm", "remove"])
    pr.add_argument("name", nargs="?")
    pr.add_argument("--power", type=int)
    pr.add_argument("--lock-clock")
    pr.add_argument("--gpu-offset", type=int)
    pr.add_argument("--mem-offset", type=int)
    pr.add_argument("--fan", type=int)
    pr.set_defaults(func=cmd_profile)

    a = sub.add_parser("autostart", help="apply a profile at every boot (systemd)")
    a.add_argument("name")
    a.set_defaults(func=cmd_autostart)

    nv = sub.add_parser("_nvml", help=argparse.SUPPRESS)   # internal, via sudo
    nv.add_argument("--fan", type=int)
    nv.add_argument("--fan-auto", action="store_true")
    nv.add_argument("--gpu-offset", type=int)
    nv.add_argument("--mem-offset", type=int)
    nv.set_defaults(func=cmd_nvml)

    o = sub.add_parser("osd", help="in-game overlay via MangoHud")
    o.add_argument("action", choices=["install", "config", "run"])
    o.add_argument("command", nargs=argparse.REMAINDER,
                   help="for 'run': -- <game/launcher>")
    o.set_defaults(func=cmd_osd)

    return p

def main():
    parser = build_parser()
    args = parser.parse_args()
    if not getattr(args, "func", None):
        args.cmd, args.interval, args.func = "monitor", 1.0, cmd_monitor
    sys.exit(args.func(args) or 0)

if __name__ == "__main__":
    main()
