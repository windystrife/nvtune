#!/usr/bin/env python3
"""
nvtune - a small MSI-Afterburner-style tool for NVIDIA GPUs on Linux.

Features
  * monitor : live TUI dashboard (temp, power, clocks, util, VRAM, fan)
  * set     : apply power limit / lock GPU clock / clock+mem offsets
  * reset   : revert everything to stock
  * profile : save / apply / list / remove named tuning profiles
  * autostart : apply a profile at every boot (systemd)
  * osd     : in-game overlay via MangoHud (install / configure / run a game)

Undervolt note (Linux/NVIDIA): the driver exposes no voltage curve. The
effective "undervolt" is to LOCK the GPU clock (nvidia-smi -lgc) and cap the
power limit (-pl); the GPU then runs that clock at the lowest voltage it needs.
An optional positive clock offset lets the same voltage reach a higher clock.
This tool wraps all of that.

Fan speed and clock offsets go through NVML (libnvidia-ml), which ships with
the driver and therefore always matches it, and needs no X server, no Coolbits
and no attached display. nvidia-settings is kept only as a fallback for drivers
too old to have the NVML setters: distros commonly ship an nvidia-settings far
older than the driver (510 vs 595 here), and the mismatch makes its writes fail
with a bare "Unknown Error".
"""
import argparse
import ctypes
import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path

PROFILE_DIR = Path(os.environ.get("NVTUNE_DIR", Path.home() / ".config" / "nvtune"))
SYSTEMD_UNIT = Path("/etc/systemd/system/nvtune-profile.service")
SELF = os.path.abspath(sys.argv[0])

# GDDR6 memory clock convention: nvidia-smi reports 4x the real (GPU-Z / GPU-T
# base) clock — e.g. it shows 6800 MHz where the real clock is 1700 MHz
# (real = smi * 2 / 8 for GDDR6's 8n prefetch). We display the real clock and
# scale the memory OFFSET by the same factor, so a "+100 MHz" offset means
# +100 MHz on the displayed real clock. NOTE: offsets now apply cleanly through
# NVML even headless, but the SCALING itself is still not bench-verified; if a
# bench shows the applied delta is off by 2x, adjust MEM_CLOCK_RATIO.
MEM_CLOCK_RATIO = 4

# ---------------------------------------------------------------- helpers ----

def _run(cmd, check=False, capture=True):
    return subprocess.run(cmd, text=True, check=check,
                          capture_output=capture)

def _as_root(cmd):
    """Prefix with sudo when we are not already root."""
    if os.geteuid() != 0:
        return ["sudo"] + cmd
    return cmd

def have(binname):
    return shutil.which(binname) is not None

def die(msg, code=1):
    print(f"nvtune: {msg}", file=sys.stderr)
    sys.exit(code)

def require_nvsmi():
    if not have("nvidia-smi"):
        die("nvidia-smi not found (install the NVIDIA driver).")

# ------------------------------------------------------------- NVAPI temps ----
# nvidia-smi/NVML do not expose GPU hotspot or VRAM (memory) temperature on
# GeForce cards. NVIDIA's Linux driver (>=555) ships libnvidia-api.so.1 which
# provides NVAPI; its internal thermal query returns per-sensor temps. We read
# the hotspot (index 9) and VRAM (index 15) sensors, fixed-point /256.
# Read-only; no root needed. Silently disabled if the library is unavailable.

class _NvAPI:
    Q_INIT, Q_ENUM, Q_BUSID, Q_THERM = 0x0150e828, 0xe5ac921f, 0x1be0b8e5, 0x65fe3aad

    def __init__(self):
        self.ok = False
        try:
            import ctypes as C
            lib = C.CDLL("libnvidia-api.so.1")
            lib.nvapi_QueryInterface.restype = C.c_void_p
            lib.nvapi_QueryInterface.argtypes = [C.c_uint]
            def qi(i):
                p = lib.nvapi_QueryInterface(i)
                if not p:
                    raise OSError("nvapi symbol missing")
                return p

            class TH(C.Structure):
                _pack_ = 1
                _fields_ = [("version", C.c_uint), ("mask", C.c_int),
                            ("values", C.c_int * 40)]
            self.C, self.TH = C, TH
            self._init  = C.CFUNCTYPE(C.c_int)(qi(self.Q_INIT))
            self._enum  = C.CFUNCTYPE(C.c_int, C.c_void_p, C.POINTER(C.c_uint))(qi(self.Q_ENUM))
            self._busid = C.CFUNCTYPE(C.c_int, C.c_void_p, C.POINTER(C.c_uint))(qi(self.Q_BUSID))
            self._therm = C.CFUNCTYPE(C.c_int, C.c_void_p, C.POINTER(TH))(qi(self.Q_THERM))
            if self._init() != 0:
                raise OSError("NvAPI_Initialize failed")
            self.handles = (C.c_void_p * 64)()
            self.count = C.c_uint(0)
            if self._enum(self.handles, C.byref(self.count)) != 0 or self.count.value == 0:
                raise OSError("EnumPhysicalGPUs failed")
            self.ver = C.sizeof(TH) | (2 << 16)
            mt = TH(version=self.ver, mask=1)
            self.mask = 0x3fff
            for bit in range(32):
                mt.mask = 1 << bit
                if self._therm(self.handles[0], C.byref(mt)) != 0:
                    self.mask = mt.mask - 1
                    break
            self.ok = True
        except Exception:
            self.ok = False

    def temps(self, bus=None):
        if not self.ok:
            return None
        C = self.C
        h = self.handles[0]
        if bus is not None:
            for i in range(self.count.value):
                b = C.c_uint(0)
                if self._busid(self.handles[i], C.byref(b)) == 0 and b.value == bus:
                    h = self.handles[i]
                    break
        s = self.TH(version=self.ver, mask=self.mask)
        if self._therm(h, C.byref(s)) != 0:
            return None
        hot, vr = s.values[9] // 256, s.values[15] // 256
        return {"hotspot": hot if 0 < hot < 255 else None,
                "vram": vr if 0 < vr < 255 else None}

_nvapi = None

def nvapi_temps(bus=None):
    """Return {'hotspot':C,'vram':C} for the GPU on PCI `bus` (int), or None."""
    global _nvapi
    if _nvapi is None:
        _nvapi = _NvAPI()
    return _nvapi.temps(bus)

def _bus_of(bus_id):
    """Parse nvidia-smi pci.bus_id ('00000000:82:00.0') -> bus number int (0x82)."""
    try:
        return int(bus_id.split(":")[-3], 16)
    except (ValueError, IndexError, AttributeError):
        return None

# ------------------------------------------------------------- gpu queries ----

QFIELDS = [
    "index", "name", "temperature.gpu", "power.draw", "power.limit",
    "power.default_limit", "power.min_limit", "power.max_limit",
    "utilization.gpu", "utilization.memory",
    "clocks.gr", "clocks.max.gr", "clocks.mem", "clocks.max.mem",
    "memory.used", "memory.total", "fan.speed", "pstate", "pci.bus_id",
]

def query(index=0):
    res = _run(["nvidia-smi",
                f"--query-gpu={','.join(QFIELDS)}",
                "--format=csv,noheader,nounits", "-i", str(index)])
    if res.returncode != 0:
        die(res.stderr.strip() or "nvidia-smi query failed")
    vals = [v.strip() for v in res.stdout.strip().split(",")]
    d = dict(zip(QFIELDS, vals))
    return d

def list_gpus():
    res = _run(["nvidia-smi", "--query-gpu=index,name", "--format=csv,noheader"])
    out = []
    for line in res.stdout.strip().splitlines():
        idx, name = line.split(", ", 1)
        out.append((int(idx), name))
    return out

def _num(x, default=0.0):
    try:
        return float(x)
    except (TypeError, ValueError):
        return default

# ---------------------------------------------------------------- monitor ----

def cmd_monitor(args):
    require_nvsmi()
    try:
        from rich.live import Live
        from rich.table import Table
        from rich import box
    except ImportError:
        return _monitor_plain(args)

    def render():
        t = Table(box=box.SIMPLE_HEAVY, title="nvtune — NVIDIA live monitor",
                  title_style="bold cyan", expand=True)
        for col in ("GPU", "Temp", "Hot", "Tmem", "Power", "GPU%", "Mem%",
                    "Core clk", "Mem clk", "VRAM", "Fan", "Pstate"):
            t.add_column(col, justify="right")
        for idx, _ in list_gpus():
            d = query(idx)
            temp = _num(d["temperature.gpu"])
            tcol = "green" if temp < 65 else "yellow" if temp < 80 else "red"

            def _tcell(v, warn, hot):
                if v is None:
                    return "—"
                c = "green" if v < warn else "yellow" if v < hot else "red"
                return f"[{c}]{v:.0f}°C[/]"
            nv = nvapi_temps(_bus_of(d.get("pci.bus_id", ""))) or {}
            hot_c = _tcell(nv.get("hotspot"), 85, 100)
            tmem_c = _tcell(nv.get("vram"), 85, 95)

            t.add_row(
                f"{d['index']} {d['name'].replace('NVIDIA ', '')[:18]}",
                f"[{tcol}]{temp:.0f}°C[/]",
                hot_c,
                tmem_c,
                f"{_num(d['power.draw']):.0f}/{_num(d['power.limit']):.0f}W",
                f"{_num(d['utilization.gpu']):.0f}%",
                f"{_num(d['utilization.memory']):.0f}%",
                f"{_num(d['clocks.gr']):.0f}/{_num(d['clocks.max.gr']):.0f}",
                f"{_num(d['clocks.mem'])/MEM_CLOCK_RATIO:.0f}/{_num(d['clocks.max.mem'])/MEM_CLOCK_RATIO:.0f}",
                f"{_num(d['memory.used'])/1024:.1f}/{_num(d['memory.total'])/1024:.1f}G",
                f"{d['fan.speed']}%" if d['fan.speed'] not in ("N/A", "[N/A]") else "—",
                d["pstate"],
            )
        return t

    with Live(render(), refresh_per_second=1, screen=False) as live:
        try:
            while True:
                time.sleep(args.interval)
                live.update(render())
        except KeyboardInterrupt:
            pass

def _monitor_plain(args):
    try:
        while True:
            d = query(args.gpu)
            nv = nvapi_temps(_bus_of(d.get("pci.bus_id", ""))) or {}
            hs = nv.get("hotspot")
            vt = nv.get("vram")
            extra = ""
            if hs is not None:
                extra += f"  hot {hs:.0f}°C"
            if vt is not None:
                extra += f"  vram {vt:.0f}°C"
            print(f"\r{d['name'].replace('NVIDIA ','')}: "
                  f"{_num(d['temperature.gpu']):.0f}°C{extra}  "
                  f"{_num(d['power.draw']):.0f}/{_num(d['power.limit']):.0f}W  "
                  f"gpu {_num(d['utilization.gpu']):.0f}%  "
                  f"core {_num(d['clocks.gr']):.0f}MHz  "
                  f"mem {_num(d['memory.used'])/1024:.1f}/"
                  f"{_num(d['memory.total'])/1024:.1f}G  fan {d['fan.speed']}   ",
                  end="", flush=True)
            time.sleep(args.interval)
    except KeyboardInterrupt:
        print()

# ------------------------------------------------------------------- apply ----

def _mark(ok):
    """✓/✗ marker, coloured only when writing to a real terminal (so the GUI,
    which captures our stdout, doesn't get raw ANSI escape codes)."""
    if sys.stdout.isatty():
        return "\033[32m✓\033[0m" if ok else "\033[31m✗\033[0m"
    return "✓" if ok else "✗"


def _ns_fail_hint(out):
    """Turn a failed nvidia-settings assignment into an actionable message.
    nvidia-settings returns exit 0 even when an assignment fails, so callers
    must scan the text for 'ERROR'. The opaque '(Unknown Error)' almost always
    means the nvidia-settings binary is older than the running driver."""
    out = (out or "").strip()
    if "Unknown Error" in out:
        return ("nvidia-settings is older than the driver, so its writes are "
                "rejected — and this driver has no NVML setter either; upgrade "
                "nvidia-settings to match the driver")
    return out or "needs Xorg + Coolbits"


# -------------------------------------------------------------------- nvml ----
# Preferred path for fan + clock offsets. NVML ships with the driver, so it can
# never be version-skewed against it, and it needs no X server, no Coolbits and
# no attached display. The setters need root, so callers re-invoke this script
# through sudo (the hidden `_nvml` subcommand), exactly like the nvidia-smi
# calls are elevated.

NVML_ERR = {3: "not supported by this driver/GPU", 4: "no permission (needs root)"}


def nvml_open(gpu):
    """Return (lib, handle) for a GPU, or raise OSError."""
    lib = ctypes.CDLL("libnvidia-ml.so.1")
    if lib.nvmlInit_v2() != 0:
        raise OSError("nvmlInit failed")
    h = ctypes.c_void_p()
    if lib.nvmlDeviceGetHandleByIndex_v2(gpu, ctypes.byref(h)) != 0:
        raise OSError(f"no NVML handle for GPU {gpu}")
    lib.nvmlDeviceSetGpcClkVfOffset.argtypes = [ctypes.c_void_p, ctypes.c_int]
    lib.nvmlDeviceSetMemClkVfOffset.argtypes = [ctypes.c_void_p, ctypes.c_int]
    return lib, h


def nvml_capable():
    """True when this driver's NVML can actually set fan / offsets."""
    try:
        lib = ctypes.CDLL("libnvidia-ml.so.1")
    except OSError:
        return False
    return all(hasattr(lib, s) for s in
               ("nvmlDeviceSetFanSpeed_v2", "nvmlDeviceSetGpcClkVfOffset"))


def _nvml_root(gpu, *flags):
    """Run the hidden `_nvml` subcommand as root. Returns (ok, detail)."""
    if not nvml_capable():
        return False, "NVML setters unavailable (driver too old)"
    r = _run(_as_root([SELF, "-i", str(gpu), "_nvml", *map(str, flags)]))
    return r.returncode == 0, (r.stdout + r.stderr).strip()


def _ns_offsets(gpu, gpu_offset, mem_offset):
    """Legacy clock-offset path via nvidia-settings (needs Xorg + Coolbits)."""
    env = dict(os.environ); env.setdefault("DISPLAY", ":0")
    args_ns = ["nvidia-settings"]
    if gpu_offset is not None:
        args_ns += ["-a", f"[gpu:{gpu}]/GPUGraphicsClockOffsetAllPerformanceLevels={gpu_offset}"]
    if mem_offset is not None:
        args_ns += ["-a", f"[gpu:{gpu}]/GPUMemoryTransferRateOffsetAllPerformanceLevels="
                          f"{int(mem_offset) * MEM_CLOCK_RATIO}"]
    r = subprocess.run(_as_root(args_ns), text=True, capture_output=True, env=env)
    ok = r.returncode == 0 and "ERROR" not in (r.stdout + r.stderr)
    return ok, ((r.stdout + r.stderr).strip() if ok
                else _ns_fail_hint(r.stdout + r.stderr))


def _ns_fan(gpu, fan):
    """Legacy fan path via nvidia-settings (needs Xorg + Coolbits)."""
    env = dict(os.environ); env.setdefault("DISPLAY", ":0")
    ns = ["nvidia-settings",
          "-a", f"[gpu:{gpu}]/GPUFanControlState=1",
          "-a", f"[fan:{gpu}]/GPUTargetFanSpeed={fan}"]
    r = subprocess.run(_as_root(ns), text=True, capture_output=True, env=env)
    ok = r.returncode == 0 and "ERROR" not in (r.stdout + r.stderr)
    return ok, ((r.stdout + r.stderr).strip() if ok
                else _ns_fail_hint(r.stdout + r.stderr))


def cmd_nvml(args):
    """Hidden: do the NVML writes in-process. Re-invoked through sudo."""
    try:
        lib, h = nvml_open(args.gpu)
    except OSError as e:
        print(f"NVML unavailable: {e}")
        return 1
    rc = 0

    def chk(what, code):
        nonlocal rc
        if code != 0:
            rc = 1
            print(f"{what}: NVML error {code} "
                  f"({NVML_ERR.get(code, 'see nvmlReturn_t')})")

    if args.fan_auto:
        chk("fan auto", lib.nvmlDeviceSetDefaultFanSpeed_v2(h, 0))
    if args.fan is not None:
        n = ctypes.c_uint()
        if lib.nvmlDeviceGetNumFans(h, ctypes.byref(n)) != 0:
            n.value = 1
        for i in range(max(1, n.value)):        # keep every fan in step
            chk(f"fan {i}", lib.nvmlDeviceSetFanSpeed_v2(h, i, args.fan))
    if args.gpu_offset is not None:
        chk("gpu offset", lib.nvmlDeviceSetGpcClkVfOffset(h, args.gpu_offset))
    if args.mem_offset is not None:
        # same real-clock -> transfer-rate convention as the nvidia-settings path
        chk("mem offset",
            lib.nvmlDeviceSetMemClkVfOffset(h, args.mem_offset * MEM_CLOCK_RATIO))
    return rc


def apply_settings(gpu, power=None, lock_clock=None, gpu_offset=None,
                   mem_offset=None, fan=None, verbose=True):
    """Apply tuning to one GPU. Returns list of (label, ok, detail)."""
    require_nvsmi()
    results = []

    # persistence mode keeps clock locks sticky
    _run(_as_root(["nvidia-smi", "-i", str(gpu), "-pm", "1"]))

    if power is not None:
        r = _run(_as_root(["nvidia-smi", "-i", str(gpu), "-pl", str(power)]))
        results.append(("power limit %sW" % power, r.returncode == 0,
                        (r.stdout + r.stderr).strip()))

    if lock_clock is not None:
        r = _run(_as_root(["nvidia-smi", "-i", str(gpu), "-lgc", lock_clock]))
        results.append(("lock core clock %s" % lock_clock, r.returncode == 0,
                        (r.stdout + r.stderr).strip()))

    # clock offsets: NVML first, legacy nvidia-settings only if NVML can't.
    # mem_offset is given in real-clock MHz (matching the displayed clock);
    # both paths scale it to the transfer-rate convention internally.
    if gpu_offset is not None or mem_offset is not None:
        flags = []
        if gpu_offset is not None:
            flags += ["--gpu-offset", gpu_offset]
        if mem_offset is not None:
            flags += ["--mem-offset", mem_offset]
        ok, detail = _nvml_root(gpu, *flags)
        if not ok:
            ok, detail = _ns_offsets(gpu, gpu_offset, mem_offset)
        results.append(("clock offset (gpu=%s mem=%s real MHz)" % (gpu_offset, mem_offset),
                        ok, detail))

    if fan is not None:
        ok, detail = _nvml_root(gpu, "--fan", fan)
        if not ok:
            ok, detail = _ns_fan(gpu, fan)
        results.append(("fan %s%%" % fan, ok, detail))

    if verbose:
        for label, ok, detail in results:
            print(f"  {_mark(ok)} {label}"
                  + (f"   ({detail.splitlines()[-1]})" if not ok and detail else ""))
    return results

def _results_rc(results):
    """Exit code from apply results: 0 if every setting stuck, else 1."""
    return 0 if all(ok for _, ok, _ in results) else 1

def cmd_set(args):
    return _results_rc(apply_settings(
        args.gpu, power=args.power, lock_clock=args.lock_clock,
        gpu_offset=args.gpu_offset, mem_offset=args.mem_offset, fan=args.fan))

def cmd_undervolt(args):
    """Convenience: lock the core clock + cap power (the Linux undervolt)."""
    lock = f"{args.clock},{args.clock}" if args.clock else None
    print(f"Undervolt GPU {args.gpu}: "
          f"lock core {args.clock}MHz, power {args.power}W"
          + (f", +{args.gpu_offset}MHz offset" if args.gpu_offset else ""))
    return _results_rc(apply_settings(args.gpu, power=args.power, lock_clock=lock,
                                      gpu_offset=args.gpu_offset))

def cmd_reset(args):
    require_nvsmi()
    for label, cmd in [
        ("unlock core clock", ["nvidia-smi", "-i", str(args.gpu), "-rgc"]),
        ("unlock mem clock",  ["nvidia-smi", "-i", str(args.gpu), "-rmc"]),
        ("default power limit", ["nvidia-smi", "-i", str(args.gpu), "-pl",
                                 query(args.gpu)["power.default_limit"].split(".")[0]]),
    ]:
        r = _run(_as_root(cmd))
        print(f"  {_mark(r.returncode == 0)} {label}")
    # zero the offsets and hand the fan back to the driver's own curve
    ok, detail = _nvml_root(args.gpu, "--gpu-offset", 0, "--mem-offset", 0,
                            "--fan-auto")
    if not ok:
        env = dict(os.environ); env.setdefault("DISPLAY", ":0")
        subprocess.run(_as_root(["nvidia-settings",
            "-a", f"[gpu:{args.gpu}]/GPUGraphicsClockOffsetAllPerformanceLevels=0",
            "-a", f"[gpu:{args.gpu}]/GPUMemoryTransferRateOffsetAllPerformanceLevels=0",
            "-a", f"[gpu:{args.gpu}]/GPUFanControlState=0"]),
            text=True, capture_output=True, env=env)
    print(f"  {_mark(ok)} offsets zeroed + fan back to auto"
          + (f"   ({detail.splitlines()[-1]})" if not ok and detail else ""))
    print("  reset done")

# ---------------------------------------------------------------- profiles ----

def cmd_profile(args):
    PROFILE_DIR.mkdir(parents=True, exist_ok=True)
    if args.action == "list":
        profs = sorted(PROFILE_DIR.glob("*.json"))
        if not profs:
            print("no profiles yet — save one with:  nvtune profile save <name> --power ...")
        for p in profs:
            data = json.loads(p.read_text())
            print(f"  {p.stem:16} {json.dumps(data)}")
    elif args.action == "save":
        data = {k: v for k, v in dict(
            gpu=args.gpu, power=args.power, lock_clock=args.lock_clock,
            gpu_offset=args.gpu_offset, mem_offset=args.mem_offset, fan=args.fan
        ).items() if v is not None}
        (PROFILE_DIR / f"{args.name}.json").write_text(json.dumps(data, indent=2))
        print(f"saved profile '{args.name}': {data}")
    elif args.action == "apply":
        p = PROFILE_DIR / f"{args.name}.json"
        if not p.exists():
            die(f"profile '{args.name}' not found")
        data = json.loads(p.read_text())
        print(f"applying profile '{args.name}': {data}")
        return _results_rc(apply_settings(**data))
    elif args.action in ("rm", "remove"):
        (PROFILE_DIR / f"{args.name}.json").unlink(missing_ok=True)
        print(f"removed profile '{args.name}'")

def cmd_autostart(args):
    p = PROFILE_DIR / f"{args.name}.json"
    if not p.exists():
        die(f"profile '{args.name}' not found — save it first")
    self_path = os.path.abspath(sys.argv[0])
    unit = f"""[Unit]
Description=Apply nvtune GPU profile '{args.name}' at boot
After=multi-user.target

[Service]
Type=oneshot
ExecStart={self_path} profile apply {args.name}
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
"""
    subprocess.run(_as_root(["tee", str(SYSTEMD_UNIT)]),
                   input=unit, text=True, capture_output=True)
    _run(_as_root(["systemctl", "daemon-reload"]))
    _run(_as_root(["systemctl", "enable", "nvtune-profile.service"]))
    print(f"profile '{args.name}' will now be applied at every boot.")
    print("  disable with:  sudo systemctl disable --now nvtune-profile.service")

